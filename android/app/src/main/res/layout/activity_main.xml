<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Header: logo · título · bolinha de status -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/logo_ipb"
                android:contentDescription="@string/app_name" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="@string/titulo"
                android:textColor="@color/ink"
                android:textSize="21sp"
                android:textStyle="bold" />
            <View
                android:id="@+id/statusDot"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/dot" />
            <TextView
                android:id="@+id/statusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/st_parado"
                android:textColor="@color/muted"
                android:textSize="13sp" />
        </LinearLayout>

        <RadioGroup
            android:id="@+id/modeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">
            <RadioButton
                android:id="@+id/modeHotspot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:buttonTint="@color/green"
                android:textColor="@color/ink"
                android:text="@string/modo_hotspot" />
            <RadioButton
                android:id="@+id/modeExisting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="@color/green"
                android:textColor="@color/ink"
                android:text="@string/modo_existente" />
        </RadioGroup>

        <Button
            android:id="@+id/toggle"
            style="@style/BotaoPrimario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/iniciar" />

        <!-- Some quando a isenção de bateria já foi concedida. -->
        <Button
            android:id="@+id/battery"
            style="@style/BotaoGhost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permitir_bateria" />

        <TextView
            android:id="@+id/detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textColor="@color/muted"
            android:visibility="gone" />

        <!-- Abas: QR Codes | Logs -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">
            <Button
                android:id="@+id/tabQr"
                style="@style/BotaoGhost"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/aba_qr" />
            <Button
                android:id="@+id/tabLogs"
                style="@style/BotaoGhost"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/aba_logs" />
        </LinearLayout>

        <!-- Aba QR Codes -->
        <LinearLayout
            android:id="@+id/qrPane"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">

            <LinearLayout
                android:id="@+id/wifiCard"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_horizontal"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/passo1"
                    android:textColor="@color/green"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/wifiQr"
                    android:layout_width="250dp"
                    android:layout_height="250dp"
                    android:layout_marginTop="8dp"
                    android:contentDescription="@string/passo1" />
                <TextView
                    android:id="@+id/wifiInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/ink"
                    android:textIsSelectable="true" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/urlCard"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_horizontal"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/passo2"
                    android:textColor="@color/green"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/urlQr"
                    android:layout_width="250dp"
                    android:layout_height="250dp"
                    android:layout_marginTop="8dp"
                    android:contentDescription="@string/passo2" />
                <TextView
                    android:id="@+id/urlInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/ink"
                    android:textIsSelectable="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Aba Logs -->
        <LinearLayout
            android:id="@+id/logsPane"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">
            <ScrollView
                android:id="@+id/logsScroll"
                android:layout_width="match_parent"
                android:layout_height="380dp"
                android:layout_marginTop="10dp"
                android:background="@color/surface">
                <TextView
                    android:id="@+id/logsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:textColor="@color/ink"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true" />
            </ScrollView>
            <Button
                android:id="@+id/copyLogs"
                style="@style/BotaoGhost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/copiar_logs" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
