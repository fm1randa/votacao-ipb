<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema claro com a identidade do app web (verde IPB sobre branco-quente). -->
    <style name="Theme.Votacao" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/green</item>
        <item name="colorPrimaryDark">@color/green_dark</item>
        <item name="colorAccent">@color/green_mid</item>
        <item name="android:windowBackground">@color/paper</item>
        <item name="android:textColorPrimary">@color/ink</item>
        <item name="android:textColorSecondary">@color/muted</item>
        <item name="android:statusBarColor">@color/paper</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="BotaoPrimario" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">@color/green</item>
        <item name="android:textColor">@color/surface</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BotaoGhost" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">@color/surface</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
